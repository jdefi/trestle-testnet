# Required - WalletConnect Project ID (from https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Backend API
VITE_API_URL=http://localhost:3001
VITE_BLOCKSCOUT_API_KEY=your_blockscout_api_key_here

# Blockscout RPC (Optional - for round-robin load balancing)
VITE_BLOCKSCOUT_API=https://polygon-blockscout.example.com
VITE_BLOCKSCOUT_API_AMOY=https://api-amoy.polygonscan.com

# Contract addresses (deployed on Polygon Amoy Testnet)
VITE_MARKETPLACE_CORE=0x...
VITE_DIGITAL_RWA=0x...
VITE_DIGITAL_GOODS=0x...
VITE_FREELANCER_ESCROW=0x...
VITE_AI_DISPUTE=0x...
VITE_FEE_DISTRIBUTOR=0x...
VITE_TIER1_STAKING=0x...
VITE_TIER2_STAKING=0x...
VITE_TIER3_VAULT=0x...
VITE_GOVERNANCE_TOKEN=0x...